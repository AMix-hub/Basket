# Supabase project credentials
# Copy this file to .env.local and fill in the values from your Supabase project settings.
# NEXT_PUBLIC_SUPABASE_ANON_KEY accepts both classic JWT keys (eyJ...) and
# the newer Supabase Publishable Keys (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
