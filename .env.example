# Firebase project credentials
# Copy this file to .env.local and fill in the values from your Firebase project settings.
# Create a project at https://console.firebase.google.com/ and enable
# Authentication (Email/Password) and Firestore Database.

# The public base URL of your deployment (no trailing slash, no "www." prefix).
# Used as the redirect URL after e-mail actions (e.g. password reset).
# Must also be listed under Firebase Console → Authentication → Settings → Authorized domains.
# ⚠️  Do NOT use the "www." subdomain here — use the bare domain (e.g. https://sport-iq.se,
#    NOT https://www.sport-iq.se).  The www subdomain typically has no DNS record and will
#    produce a "DNS_PROBE_FINISHED_NXDOMAIN" error for users who click email links.
NEXT_PUBLIC_BASE_URL=https://sport-iq.se
# Preferred alias for the public app URL (used in invitation email links).
# Same rule applies: no "www." prefix.
NEXT_PUBLIC_APP_URL=https://sport-iq.se
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDbnTyfG-LG7x6poewTrNM0pGx-UYr_764
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sport-iq.se
NEXT_PUBLIC_FIREBASE_PROJECT_ID=basketpi-c1e0b
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=basketpi-c1e0b.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=650053767032
NEXT_PUBLIC_FIREBASE_APP_ID=1:650053767032:web:344c366ea6f92e68a6028d
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ZJ2ZQT748H

# Web Push (FCM) — needed for browser push notifications.
# This is the PUBLIC VAPID key from Firebase Console → Project Settings →
# Cloud Messaging → Web push certificates → Generate key pair.
# This value is safe to expose to the browser (it is a public key).
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BPRaxN5zTMG-U84Q4iuJfXqfWXWKHTaPBXBwwIdHwZhbytLUmw49lKvpTsfaxErQgm1W0bT2MNQVshQxZ9QUtQo

# Firebase Admin SDK — needed for the /api/notify server route that sends
# push notifications and queues emails when a training session is cancelled.
# 1. Go to Firebase Console → Project Settings → Service accounts
# 2. Click "Generate new private key" and download the JSON file
# 3. Paste the entire JSON content (stringified / single-line) as the value below.
# WARNING: Never commit this value to source control!
FIREBASE_SERVICE_ACCOUNT=

# ─── Resend (e-mail delivery) ─────────────────────────────────────────────────
# Used by /api/create-user (welcome e-mail) and /api/notify (session cancellation).
#
# 1. Create a free account at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste the key below
# WARNING: Never commit this value to source control!
RESEND_API_KEY=

# The e-mail address that will appear in the "From" field of outgoing e-mails.
# This address (or its domain) must be verified in Resend → Domains.
RESEND_FROM=no-reply@sport-iq.se
