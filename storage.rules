rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Club logos ────────────────────────────────────────────────
    // Each admin can upload/overwrite their own logo.
    // Everyone (including unauthenticated users) can read, so the logo
    // is visible in the app for all team members.
    match /clubLogos/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size <= 2 * 1024 * 1024;
    }

  }
}
