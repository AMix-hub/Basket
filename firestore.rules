rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId)).data;
    }

    function isTeamMember(teamId) {
      return exists(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid));
    }

    function userRole() {
      return getProfile(request.auth.uid).role;
    }

    function isCoachOrAbove() {
      return userRole() in ['coach', 'assistant', 'admin'];
    }

    function getTeamData(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data;
    }

    // Returns the effective admin ID for the current user: for co-admins this
    // is their stored adminId (pointing to the root admin); for root admins it
    // is their own UID.  Used to scope all club-level Firestore operations.
    function effectiveAdminId() {
      let p = getProfile(request.auth.uid);
      return p.adminId != null ? p.adminId : request.auth.uid;
    }

    // ─── profiles ────────────────────────────────────────────────
    // Public read (needed for invite-code validation before sign-up).
    // Each user manages only their own row; club admins can also manage
    // the profiles of users in their club (e.g. role / adminId updates).
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (
        isOwner(userId) ||
        // Club admin (root or co-admin) can update profiles of their members
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
    }

    // ─── teams ───────────────────────────────────────────────────
    // Public read (invite-code validation).
    // Authenticated users can create teams.
    // Only coach or admin (including co-admin) can update their own team.
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.coachId == request.auth.uid ||
        resource.data.adminId == request.auth.uid ||
        // Co-admin: effectiveAdminId resolves to the club's root admin
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
      allow delete: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
    }

    // ─── team_members ─────────────────────────────────────────────
    // Authenticated users can read all memberships.
    // Users can add themselves, or a coach can add the admin of a team they
    // coach, or an admin can add any member to their club's teams.
    match /team_members/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
        ||
        // Coach creating a team can add the team's admin as a member
        (
          request.resource.data.userId == getTeamData(request.resource.data.teamId).adminId
          && getTeamData(request.resource.data.teamId).coachId == request.auth.uid
        )
        ||
        // Admin (root or co-admin) can add members to their club's teams
        (
          userRole() == 'admin' &&
          getTeamData(request.resource.data.teamId).adminId == effectiveAdminId()
        )
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isTeamMember(resource.data.teamId) ||
        // Admin can remove members from their club's teams
        (
          userRole() == 'admin' &&
          getTeamData(resource.data.teamId).adminId == effectiveAdminId()
        )
      );
    }

    // ─── messages ────────────────────────────────────────────────
    // Only team members can read/write messages in their team.
    match /messages/{msgId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        isTeamMember(request.resource.data.teamId);
      allow update: if isSignedIn() && isTeamMember(resource.data.teamId);
    }

    // ─── coach_chat ───────────────────────────────────────────────
    // Global channel for coaches, assistants and admins only.
    match /coach_chat/{msgId} {
      allow read: if isSignedIn() && isCoachOrAbove();
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        isCoachOrAbove();
      allow update: if isSignedIn() && isCoachOrAbove();
    }

    // ─── players ─────────────────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create, update: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── sessions ────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create, update: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── attendance ───────────────────────────────────────────────
    // Coaches and above can read/write all attendance.
    // Any signed-in team member can write their own attendance entry (RSVP).
    match /attendance/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isCoachOrAbove() ||
        // Players can write their own RSVP (playerId must match their uid)
        request.resource.data.playerId == request.auth.uid
      );
    }

    // ─── tactics ─────────────────────────────────────────────────
    match /tactics/{tacticId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow write: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() && isTeamMember(resource.data.teamId) && isCoachOrAbove();
    }

    // ─── tactic_live_state ────────────────────────────────────────
    // One document per team (document ID = teamId).
    // Public read: the cast receiver page (/cast) is opened on an external
    // screen (TV/Chromecast) and runs without authentication.  The document
    // only contains tactical board state (player positions, drawings) which
    // is not sensitive personal data.  Writes remain coach-only.
    match /tactic_live_state/{teamId} {
      allow read: if true;
      allow write: if isSignedIn() && isTeamMember(teamId) && isCoachOrAbove();
    }

    // ─── coach_notes ──────────────────────────────────────────────
    // Each user can only access their own notes.
    match /coach_notes/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ─── mail ─────────────────────────────────────────────────────
    // Written by the server (API route via Admin SDK) when a session is
    // cancelled.  The Firebase Trigger Email extension reads and sends them.
    // Client code should never write directly to this collection.
    match /mail/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ─── halls ────────────────────────────────────────────────────
    // Admins manage halls for their association. All signed-in users can read
    // (needed for calendar hall selection by coaches).
    // Co-admins store and query halls under the root admin's ID (effectiveAdminId).
    match /halls/{hallId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        userRole() == 'admin' &&
        request.resource.data.adminId == effectiveAdminId();
      allow update: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
      allow delete: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
    }

    // ─── training_free_periods ────────────────────────────────────
    // Admins create/manage training-free periods (holidays).
    // All signed-in users can read (needed for calendar display and
    // recurring session generation).
    // Co-admins store and query periods under the root admin's ID.
    match /training_free_periods/{periodId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        userRole() == 'admin' &&
        request.resource.data.adminId == effectiveAdminId();
      allow update: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
      allow delete: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        (userRole() == 'admin' && resource.data.adminId == effectiveAdminId())
      );
    }

    // ─── session_notes ────────────────────────────────────────────
    // Coach/admin notes on training plan sessions (sub-activities, comments).
    // Readable by all team members; writable by coach+.
    match /session_notes/{noteId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isCoachOrAbove();
      allow delete: if isSignedIn() && isCoachOrAbove();
    }

    // ─── team_exercises ───────────────────────────────────────────
    // Custom exercises created by coaches/admins for a team.
    // Readable by all team members; writable by coach+.
    match /team_exercises/{exerciseId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow update: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── custom_season_plans ──────────────────────────────────────
    // Coaches/admins can create and manage their own annual training
    // plans, built from exercises in the training database.
    // Readable by all team members; writable by coach+.
    match /custom_season_plans/{planId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow update: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── player_groups ────────────────────────────────────────────    // Groups of players within a team. Readable by all team members;
    // creatable/updatable/deletable by coaches and admins.
    match /player_groups/{groupId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow update: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── rsvps ───────────────────────────────────────────────────
    // Any team member can read RSVPs for their team and write their own.
    // Coaches/admins can read all RSVPs (for head-count).
    match /rsvps/{docId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create, update: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        isTeamMember(request.resource.data.teamId);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── player_notes ─────────────────────────────────────────────
    // Coaches/admins write notes per player; the player and their
    // parents can read notes for themselves.
    match /player_notes/{noteId} {
      allow read: if isSignedIn() && (
        isCoachOrAbove() ||
        resource.data.playerId == request.auth.uid
      );
      allow create: if isSignedIn() && isCoachOrAbove() &&
        request.resource.data.coachId == request.auth.uid;
      allow update: if isSignedIn() &&
        isCoachOrAbove() &&
        resource.data.coachId == request.auth.uid;
      allow delete: if isSignedIn() &&
        isCoachOrAbove() &&
        resource.data.coachId == request.auth.uid;
    }

    // ─── dev_items ────────────────────────────────────────────────
    // Development tracking items. Accessible only to admins.
    match /dev_items/{itemId} {
      allow read, write: if isSignedIn() && userRole() == 'admin';
    }

    // ─── dev_item_comments ────────────────────────────────────────
    // Comments on development items. Only admins can read/write.
    match /dev_item_comments/{commentId} {
      allow read: if isSignedIn() && userRole() == 'admin';
      allow create: if isSignedIn() &&
        userRole() == 'admin' &&
        request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() &&
        userRole() == 'admin' &&
        resource.data.authorId == request.auth.uid;
    }
  }
}
