rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId)).data;
    }

    function isTeamMember(teamId) {
      return exists(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid));
    }

    function userRole() {
      return getProfile(request.auth.uid).role;
    }

    function isCoachOrAbove() {
      return userRole() in ['coach', 'assistant', 'admin'];
    }

    function getTeamData(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data;
    }

    // ─── profiles ────────────────────────────────────────────────
    // Public read (needed for invite-code validation before sign-up).
    // Each user manages only their own row.
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
    }

    // ─── teams ───────────────────────────────────────────────────
    // Public read (invite-code validation).
    // Authenticated users can create teams.
    // Only coach or admin can update their own team.
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.coachId == request.auth.uid ||
        resource.data.adminId == request.auth.uid
      );
      allow delete: if isSignedIn() && resource.data.adminId == request.auth.uid;
    }

    // ─── team_members ─────────────────────────────────────────────
    // Authenticated users can read all memberships.
    // Users can add themselves, or a coach can add the admin of a team they coach.
    match /team_members/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
        ||
        // Coach creating a team can add the team's admin as a member
        (
          request.resource.data.userId == getTeamData(request.resource.data.teamId).adminId
          && getTeamData(request.resource.data.teamId).coachId == request.auth.uid
        )
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isTeamMember(resource.data.teamId)
      );
    }

    // ─── messages ────────────────────────────────────────────────
    // Only team members can read/write messages in their team.
    match /messages/{msgId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        isTeamMember(request.resource.data.teamId);
      allow update: if isSignedIn() && isTeamMember(resource.data.teamId);
    }

    // ─── coach_chat ───────────────────────────────────────────────
    // Global channel for coaches, assistants and admins only.
    match /coach_chat/{msgId} {
      allow read: if isSignedIn() && isCoachOrAbove();
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        isCoachOrAbove();
      allow update: if isSignedIn() && isCoachOrAbove();
    }

    // ─── players ─────────────────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create, update: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── sessions ────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create, update: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }

    // ─── attendance ───────────────────────────────────────────────
    // Coaches and above can read/write all attendance.
    // Any signed-in team member can write their own attendance entry (RSVP).
    match /attendance/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isCoachOrAbove() ||
        // Players can write their own RSVP (playerId must match their uid)
        request.resource.data.playerId == request.auth.uid
      );
    }

    // ─── tactics ─────────────────────────────────────────────────
    match /tactics/{tacticId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow write: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() && isTeamMember(resource.data.teamId) && isCoachOrAbove();
    }

    // ─── tactic_live_state ────────────────────────────────────────
    // One document per team (document ID = teamId).
    match /tactic_live_state/{teamId} {
      allow read: if isSignedIn() && isTeamMember(teamId);
      allow write: if isSignedIn() && isTeamMember(teamId) && isCoachOrAbove();
    }

    // ─── coach_notes ──────────────────────────────────────────────
    // Each user can only access their own notes.
    match /coach_notes/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ─── mail ─────────────────────────────────────────────────────
    // Written by the server (API route via Admin SDK) when a session is
    // cancelled.  The Firebase Trigger Email extension reads and sends them.
    // Client code should never write directly to this collection.
    match /mail/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ─── halls ────────────────────────────────────────────────────
    // Admins manage halls for their association. All signed-in users can read
    // (needed for calendar hall selection by coaches).
    match /halls/{hallId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.adminId == request.auth.uid &&
        userRole() == 'admin';
      allow update: if isSignedIn() &&
        resource.data.adminId == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.adminId == request.auth.uid;
    }

    // ─── training_free_periods ────────────────────────────────────
    // Admins create/manage training-free periods (holidays).
    // All signed-in users can read (needed for calendar display and
    // recurring session generation).
    match /training_free_periods/{periodId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.adminId == request.auth.uid &&
        userRole() == 'admin';
      allow update: if isSignedIn() &&
        resource.data.adminId == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.adminId == request.auth.uid;
    }

    // ─── session_notes ────────────────────────────────────────────
    // Coach/admin notes on training plan sessions (sub-activities, comments).
    // Readable by all team members; writable by coach+.
    match /session_notes/{noteId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isCoachOrAbove();
      allow delete: if isSignedIn() && isCoachOrAbove();
    }

    // ─── team_exercises ───────────────────────────────────────────
    // Custom exercises created by coaches/admins for a team.
    // Readable by all team members; writable by coach+.
    match /team_exercises/{exerciseId} {
      allow read: if isSignedIn() && isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() &&
        isTeamMember(request.resource.data.teamId) &&
        isCoachOrAbove();
      allow update: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
      allow delete: if isSignedIn() &&
        isTeamMember(resource.data.teamId) &&
        isCoachOrAbove();
    }
  }
}
